# Backend API base URL (used by Vite proxy in dev and by API/WS client in production).
# Default: http://127.0.0.1:8000
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: WebSocket base URL. If unset, derived from VITE_API_BASE_URL (http→ws, https→wss),
# or same-origin when API_BASE_URL is empty.
# VITE_WS_BASE_URL=ws://127.0.0.1:8000
